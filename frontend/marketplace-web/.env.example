# ==============================================
# Environment Variables Template
# Copy this to .env.local for local development
# ==============================================

# ---------------------------------------------
# Core API Services
# ---------------------------------------------
# Main marketplace backend API
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Content management service
NEXT_PUBLIC_CONTENT_API_URL=http://localhost:8083/api/v1

# Learning management system (LMS) service
NEXT_PUBLIC_LMS_SERVICE_URL=http://localhost:8082/api

# ---------------------------------------------
# Dashboard URLs
# ---------------------------------------------
# Admin dashboard (runs on separate port)
NEXT_PUBLIC_ADMIN_DASHBOARD_URL=http://localhost:3001

# Main marketplace web app
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ---------------------------------------------
# Authentication & Security
# ---------------------------------------------
# OAuth providers (if using social login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id

# ---------------------------------------------
# Feature Flags
# ---------------------------------------------
NEXT_PUBLIC_ENABLE_ADMIN_FEATURES=true
NEXT_PUBLIC_ENABLE_LMS_FEATURES=true

# ---------------------------------------------
# Analytics & Monitoring (Optional)
# ---------------------------------------------
# NEXT_PUBLIC_GA_TRACKING_ID=UA-XXXXXXXXX-X
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ---------------------------------------------
# Production Overrides
# ---------------------------------------------
# In production, override these with your actual domains:
# NEXT_PUBLIC_API_URL=https://api.yourcompany.com
# NEXT_PUBLIC_ADMIN_DASHBOARD_URL=https://admin.yourcompany.com
# NEXT_PUBLIC_APP_URL=https://www.yourcompany.com
